LAUNCHCLAW_APP_NAME=LaunchClaw API
LAUNCHCLAW_APP_ENV=development
LAUNCHCLAW_CORS_ORIGIN=http://localhost:3000
LAUNCHCLAW_SUPABASE_URL=http://127.0.0.1:54321
LAUNCHCLAW_SUPABASE_SERVICE_KEY=your-service-role-key
LAUNCHCLAW_GITHUB_APP_CLIENT_ID=your-github-app-client-id
LAUNCHCLAW_GITHUB_APP_CLIENT_SECRET=your-github-app-client-secret
LAUNCHCLAW_GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app/installations/new
LAUNCHCLAW_GITHUB_APP_ID=your-github-app-id
LAUNCHCLAW_GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
LAUNCHCLAW_INTERNAL_SERVICE_TOKEN=your-internal-service-token
